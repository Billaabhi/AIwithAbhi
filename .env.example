# xAI — BACKEND ONLY. Never put in NEXT_PUBLIC_* vars.
XAI_API_KEY=your-xai-key-here

# Database (Neon for prod, local Postgres for dev)
DATABASE_URL=postgresql://user:pass@localhost:5432/aiwithabhi

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend (points at FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000
